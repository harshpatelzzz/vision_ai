# Copy to .env.local and adjust as needed.

# Where the FastAPI edge node lives. Used by the Vite dev proxy (/api -> here).
VITE_API_TARGET=http://127.0.0.1:8000

# Base path the frontend uses for REST calls.
# Dev (default): "/api" routes through the Vite proxy (no CORS needed).
# Prod: set to the absolute backend URL, e.g. https://edge-node.local:8000
VITE_API_BASE=/api

# WebSocket base. Dev: leave blank to reuse the page origin (proxied).
# Prod: ws(s)://edge-node.local:8000
VITE_WS_BASE=
